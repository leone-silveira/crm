generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  CLIENT_ADMIN
  WORKER
  WORKER_TRUST
}

enum ConversationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ConversationCategory {
  INQUIRY
  BOOKING
  SUPPORT
  COMPLAINT
  GENERAL
}

enum Priority {
  LOW
  NORMAL
  HIGH
  VIP
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  STICKER
  LOCATION
  CONTACT
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  name           String
  role           Role     @default(WORKER)
  isActive       Boolean  @default(true)
  avatarUrl      String?
  clientAdminId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clientAdmin   User?  @relation("TeamMembers", fields: [clientAdminId], references: [id])
  teamMembers   User[] @relation("TeamMembers")

  conversations  Conversation[] @relation("AssignedWorker")
  refreshTokens  RefreshToken[]
  ownedInstances WhatsAppInstance[] @relation("InstanceOwner")
  ownedConversations Conversation[] @relation("ConversationOwner")

  @@index([clientAdminId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Contact {
  id          String   @id @default(cuid())
  phone       String   @unique
  name        String?
  pushName    String?
  email       String?
  profilePic  String?
  notes       String?
  isVip       Boolean  @default(false)
  isGroup     Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversations Conversation[]
  tags          ContactTag[]

  @@index([phone])
  @@index([name])
  @@index([email])
  @@index([isVip])
  @@map("contacts")
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  color     String       @default("#3B82F6")
  createdAt DateTime     @default(now())

  contacts ContactTag[]

  @@map("tags")
}

model ContactTag {
  contactId String
  tagId     String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([contactId, tagId])
  @@map("contact_tags")
}

model WhatsAppInstance {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String?
  phone         String?
  status        String   @default("disconnected")
  qrCode        String?
  webhookUrl    String?
  isActive      Boolean  @default(true)
  clientAdminId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clientAdmin   User? @relation("InstanceOwner", fields: [clientAdminId], references: [id])
  conversations Conversation[]

  @@index([clientAdminId])
  @@index([status])
  @@map("whatsapp_instances")
}

model Conversation {
  id              String               @id @default(cuid())
  contactId       String
  contact         Contact              @relation(fields: [contactId], references: [id])
  instanceId      String?
  instance        WhatsAppInstance?    @relation(fields: [instanceId], references: [id])
  assignedToId    String?
  assignedTo      User?                @relation("AssignedWorker", fields: [assignedToId], references: [id])
  clientAdminId   String?
  clientAdmin     User?                @relation("ConversationOwner", fields: [clientAdminId], references: [id])
  status          ConversationStatus   @default(OPEN)
  category        ConversationCategory @default(GENERAL)
  priority        Priority             @default(NORMAL)
  unreadCount     Int                  @default(0)
  lastMessageAt   DateTime?
  slaDeadline     DateTime?
  firstResponseAt DateTime?
  metadata        Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  messages Message[]

  @@unique([contactId, instanceId])
  @@index([status])
  @@index([assignedToId])
  @@index([lastMessageAt])
  @@index([clientAdminId])
  @@index([category])
  @@index([priority])
  @@map("conversations")
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  evolutionId    String?          @unique
  direction      MessageDirection @default(INBOUND)
  type           MessageType      @default(TEXT)
  body           String?
  mediaUrl       String?
  mimeType       String?
  fileName       String?
  duration       Int?
  latitude       Float?
  longitude      Float?
  status         MessageStatus    @default(SENT)
  timestamp      DateTime         @default(now())
  metadata       Json?
  createdAt      DateTime         @default(now())

  @@index([conversationId, timestamp])
  @@index([evolutionId])
  @@map("messages")
}
