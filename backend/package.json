{
  "name": "crm-backend",
  "version": "1.0.0",
  "description": "CRM WhatsApp Backend - Fastify + Prisma + Socket.io",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "prisma generate && tsc",
    "start": "tsx src/app.ts",
    "deploy": "prisma migrate deploy && tsx prisma/seed.ts",
    "db:baseline": "npx prisma migrate resolve --applied 20260320000000_init",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.1",
    "@hapi/boom": "^10.0.1",
    "@prisma/client": "^5.14.0",
    "@whiskeysockets/baileys": "^6.7.16",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.8",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "ioredis": "^5.3.2",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "prisma": "^5.14.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.5",
    "tsx": "^4.15.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.2",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.4.5"
  }
}
